{
  "mcpServers": {
    "claude-warnerco-schematica": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "warnerco-mcp"],
      "cwd": "C:/github/context-engineering/src/warnerco/backend",
      "env": {
        "MEMORY_BACKEND": "chroma"
      },
      "permissions": {
        "sampling": "allowed"
      }
    },
    "claude-warnerco-coala-memory": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "warnerco-mcp"],
      "cwd": "C:/github/context-engineering/src/warnerco/backend",
      "env": {
        "MEMORY_BACKEND": "chroma",
        "EPISODIC_DB_PATH": "data/episodic/events.db",
        "EPISODIC_MAX_RETRIEVAL_K": "5",
        "EPISODIC_RECENCY_HALF_LIFE_HOURS": "24.0",
        "EPISODIC_WEIGHT_RECENCY": "0.4",
        "EPISODIC_WEIGHT_IMPORTANCE": "0.3",
        "EPISODIC_WEIGHT_RELEVANCE": "0.3"
      },
      "permissions": {
        "sampling": "allowed"
      }
    }
  }
}
