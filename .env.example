# Repo-root secrets template for "Context Engineering with MCP"
# Copy to .env and fill in real values. .env is gitignored; this file ships.

# Anthropic Console API key from https://console.anthropic.com/settings/keys
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Default model for Lab 02 MCP Chat CLI
CLAUDE_MODEL=claude-sonnet-4-6
