%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e8f5e9', 'secondaryColor': '#fce4ec', 'tertiaryColor': '#fff3e0'}}}%%
flowchart TB
    subgraph Clients["🖥️ MCP Clients"]
        CD["Claude Desktop"]
        VSC["VS Code/Copilot"]
        INSP["MCP Inspector"]
    end

    subgraph FastAPI["⚡ FastAPI + FastMCP"]
        API["/api/* REST"]
        MCP["/mcp SSE"]
        DASH["/dash/* SPA"]
    end

    subgraph Tools["🔧 MCP Tools (23 Total)"]
        direction TB
        VT["Vector + CRUD Tools\nlist, get, search, stats\ncreate, update, delete\nindex, compare, guided, feedback"]
        GT["Graph Tools\nadd_rel, neighbors, path, stats"]
        ST["Scratchpad Tools\nwrite, read, clear, stats"]
        MT["Meta Tools\nwarn_search_tools\nwarn_describe_tool"]
    end

    subgraph Pipeline["🔄 LangGraph 9-Node Pipeline"]
        direction LR
        N1["1️⃣ parse\nintent"] --> N2["2️⃣ query\ngraph"]
        N2 --> N3["3️⃣ inject\nscratchpad"]
        N3 --> N3b["4️⃣ recall\nepisodes"]
        N3b --> N4["5️⃣ retrieve\nvectors"]
        N4 --> N5["6️⃣ compress\ncontext"]
        N5 --> N6["7️⃣ reason\nLLM"]
        N6 --> N7["8️⃣ respond"]
        N7 --> N8["9️⃣ log\nepisode"]
    end

    subgraph Memory["💾 Hybrid Memory Layer"]
        direction TB
        VS["📊 Vector Store\nJSON→Chroma→Azure"]
        GS["🕸️ Graph Store\nSQLite+NetworkX"]
        SP["📝 Scratchpad\nIn-Memory Session"]
    end

    subgraph Data["📁 Data"]
        JSON[("schematics.json\n25 Robots")]
        GRAPH[("data/graph/<br/>knowledge.db")]
    end

    Clients --> FastAPI
    FastAPI --> Tools
    Tools --> Pipeline
    N2 -.-> GS
    N3 -.-> SP
    N4 -.-> VS
    VS --> JSON
    GS --> GRAPH

    classDef client fill:#e3f2fd,stroke:#1565c0
    classDef api fill:#fff3e0,stroke:#e65100
    classDef tool fill:#f3e5f5,stroke:#7b1fa2
    classDef pipeline fill:#e8f5e9,stroke:#2e7d32
    classDef memory fill:#fce4ec,stroke:#c2185b
    classDef data fill:#eceff1,stroke:#546e7a

    class CD,VSC,INSP client
    class API,MCP,DASH api
    class VT,GT,ST,MT tool
    class N1,N2,N3,N4,N5,N6,N7 pipeline
    class VS,GS,SP memory
    class JSON,GRAPH data
